---
import translations from './gallery.json';
import { getLocaleFromUrl } from '~/i18n/translator';
import { SITE } from '~/utils/config';

const locale = getLocaleFromUrl(Astro.url) || 'en';
const langDataRaw = (translations[locale] || translations['en']) as any[];

const base = SITE.base === '/' ? '' : SITE.base;

const langData = langDataRaw.map(p => ({
  ...p,
  images: p.images.map(img => img.startsWith('/') ? `${base}${img}` : img),
  technologies: (p.technologies || []).map(t => ({
    ...t,
    iconPath: t.icon ? `${base}/icons/${t.icon}.svg` : null
  }))
}));

const titleDict = {
    'en': 'Projects Gallery',
    'ru': 'Галерея проектов',
    'uk': 'Галерея проектів',
    'it': 'Galleria dei Progetti'
};
const listTitle = titleDict[locale] || titleDict['en'];

const allCategoriesKeys = {
    'en': 'All',
    'ru': 'Всё',
    'uk': 'Всі',
    'it': 'Tutti'
};
const allCategories = allCategoriesKeys[locale] || allCategoriesKeys['en'];

const uniqueCategories = [allCategories, ...Array.from(new Set(langData.map(p => p.category)))];

---

<style>
/* CSS для Галереи */
.gallery-section {
    padding: 4rem 1rem;
    max-width: 1200px;
    margin: 0 auto;
}
.gallery-filters {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
}
.filter-btn {
    padding: 0.5rem 1.25rem;
    border-radius: 9999px;
    background: transparent;
    border: 1px solid var(--aw-color-border, #e5e7eb);
    color: var(--aw-color-text-muted, #6b7280);
    cursor: pointer;
    transition: all 0.3s ease;
    font-weight: 500;
}
.filter-btn:hover, .filter-btn.active {
    background: var(--aw-color-primary, #2563eb);
    color: #fff;
    border-color: var(--aw-color-primary, #2563eb);
}
.dark .filter-btn {
    border-color: #374151;
    color: #9ca3af;
}
.dark .filter-btn:hover, .dark .filter-btn.active {
    background: #3b82f6;
    color: #fff;
    border-color: #3b82f6;
}

.gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
}
.project-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    overflow: hidden;
    transition: opacity 0.3s ease, transform 0.3s ease;
}
.project-card.hidden-card {
    display: none;
}
.project-img-container {
    border-radius: 1.5rem;
    overflow: hidden;
    cursor: pointer;
    background: #f3f4f6;
    aspect-ratio: 16/9;
}
.project-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
    display: block;
}
.project-img-container:hover .project-img {
    transform: scale(1.05);
}
.project-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
}
.project-title {
    font-weight: 800;
    font-size: 1.1rem;
    margin: 0;
    color: var(--aw-color-text-heading, #111827);
}
.project-slogan {
    font-size: 0.9rem;
    color: var(--aw-color-text-muted, #6b7280);
}
.project-links a {
    padding: 0.5rem;
    border-radius: 0.5rem;
    background: rgba(0,0,0,0.05);
    color: inherit;
    transition: all 0.2s;
    font-size: 0.8rem;
    font-weight: 600;
}
.project-links a:hover {
    background: #111827;
    color: #fff;
}
.dark .project-title {
    color: #fff;
}
.dark .project-links a {
    background: rgba(255,255,255,0.1);
}
.dark .project-links a:hover {
    background: #fff;
    color: #000;
}

/* Modal CSS */
.gallery-modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(4px);
    z-index: 100;
    display: flex;
    justify-content: center;
    align-items: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
}
.gallery-modal-overlay.active {
    opacity: 1;
    pointer-events: auto;
}

.gallery-modal-content {
    background: var(--aw-color-bg-page, #ffffff);
    border-radius: 1rem;
    width: 95%;
    max-width: 1100px;
    max-height: 90vh;
    overflow: hidden;
    position: relative;
    transform: scale(0.95);
    transition: transform 0.3s ease;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.2);
    display: flex;
    flex-direction: column;
}
.dark .gallery-modal-content {
    background: #111827;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
}
@media (min-width: 1024px) {
    .gallery-modal-content {
        flex-direction: row;
        height: 80vh;
    }
}
.gallery-modal-overlay.active .gallery-modal-content {
    transform: scale(1);
}

.modal-left {
    flex: 1.6;
    background: #000;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    height: 350px;
}
@media (min-width: 1024px) {
    .modal-left {
        height: auto;
    }
}
.modal-right {
    flex: 1;
    overflow-y: auto;
    background: var(--aw-color-bg-page, #ffffff);
}
.dark .modal-right {
    background: #111827;
}

/* Carousel Inner Styles */
.modal-carousel-container {
    width: 100%;
    height: 100%;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
}
#modal-main-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
}
.carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255, 255, 255, 0.8);
    color: #000;
    border: none;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    font-size: 1.2rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    z-index: 10;
}
.carousel-btn:hover {
    background: rgba(255, 255, 255, 1);
}
.carousel-btn.prev {
    left: 1rem;
}
.carousel-btn.next {
    right: 1rem;
}
.carousel-counter {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    background: rgba(255, 255, 255, 0.9);
    color: #000;
    padding: 0.2rem 0.6rem;
    border-radius: 0.5rem;
    font-size: 0.8rem;
    font-weight: 600;
}
.modal-close-btn {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 50;
    background: transparent;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: #4b5563;
    width: 32px;
    height: 32px;
    display: flex;
    justify-content: center;
    align-items: center;
    border-radius: 50%;
    transition: background 0.2s, color 0.2s;
}
.modal-close-btn:hover {
    background: rgba(0, 0, 0, 0.1);
    color: #111827;
}
.dark .modal-close-btn {
    color: #9ca3af;
}
.dark .modal-close-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
}

/* Technologies List */
.tech-item {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.91rem;
}
.tech-item img {
    height: 1rem !important;
    max-height: 16px !important;
    width: auto !important;
}
</style>

<section class="gallery-section" id="portfolio">
    <h2 class="text-3xl font-bold mb-8 text-center">{listTitle}</h2>
    
    <!-- Filters -->
    <div class="gallery-filters" id="gallery-filters">
        {uniqueCategories.map(cat => (
            <button class={`filter-btn ${cat === allCategories ? 'active' : ''}`} data-filter={cat === allCategories ? 'all' : cat}>
                {cat}
            </button>
        ))}
    </div>

    <!-- Cards -->
    <div class="gallery-grid" id="gallery-container">
        {langData.map((project) => (
            <article class="project-card" data-category={project.category}>
                <div class="project-img-container open-modal-btn" data-project={JSON.stringify({
                    title: project.title,
                    description: project.description,
                    images: project.images,
                    technologies: project.technologies || [],
                    repo: project.projectRepo || '',
                    site: project.projectSite || ''
                })}>
                    <img class="project-img" src={project.images[0]} alt={project.title} loading="lazy" />
                </div>
                <div class="project-info mt-2">
                    <div>
                        <h3 class="project-title">{project.title}</h3>
                        <span class="project-slogan">{project.slogan}</span>
                    </div>
                </div>
            </article>
        ))}
    </div>
</section>

<!-- Модальное окно ProjectModal (2 Columns layout) -->
<div class="gallery-modal-overlay" id="gallery-modal">
    <div class="gallery-modal-content">
        <button class="modal-close-btn" id="modal-close" aria-label="Close modal">×</button>
        
        <div class="modal-left">
            <div class="modal-carousel-container">
               <button class="carousel-btn prev" id="carousel-prev">❮</button>
               <img id="modal-main-image" src="" alt="Project Image" loading="lazy" />
               <button class="carousel-btn next" id="carousel-next">❯</button>
               <div class="carousel-counter" id="carousel-counter">1 / 4</div>
            </div>
        </div>

        <div class="modal-right flex flex-col p-6 lg:p-10">
            <h1 class="font-extrabold text-2xl sm:text-3xl mb-6 text-gray-900 dark:text-white" id="modal-title">Project Title</h1>
            
            <div class="flex items-center gap-3 mb-8">
                <a href="#" id="modal-repo-link" target="_blank" class="hidden justify-center px-4 py-2 flex items-center gap-2 font-semibold text-sm bg-gray-100 text-gray-900 hover:bg-gray-200 dark:bg-white/10 dark:hover:bg-white dark:hover:text-black dark:text-white transition-colors rounded-lg">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                        <path d="M9 18c-4.51 2-5-2-7-2" />
                    </svg>
                    GitHub
                </a>
                <a href="#" id="modal-site-link" target="_blank" class="hidden justify-center px-4 py-2 flex items-center gap-2 font-semibold text-sm bg-gray-100 text-gray-900 hover:bg-gray-200 dark:bg-white/10 dark:hover:bg-white dark:hover:text-black dark:text-white transition-colors rounded-lg">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="15 3 21 3 21 9" />
                        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                        <line x1="10" y1="14" x2="21" y2="3" />
                    </svg>
                    Ir al sitio
                </a>
            </div>
            
            <p class="text-[0.91rem] text-gray-700 dark:text-gray-300 mb-8 leading-relaxed whitespace-pre-wrap" id="modal-desc"></p>
            
            <h2 class="font-bold text-[1rem] mb-4 text-gray-900 dark:text-white">Tecnologías</h2>
            <ul class="flex flex-wrap gap-x-4 gap-y-3 m-0 p-0 list-none text-gray-800 dark:text-gray-300" id="modal-tech">
                <!-- Javascript will populate this -->
            </ul>
        </div>
    </div>
</div>

<script define:vars={{ base }}>
    document.addEventListener('DOMContentLoaded', () => {
        // Фильтры
        const filterBtns = document.querySelectorAll('.filter-btn');
        const projectCards = document.querySelectorAll('.project-card');

        filterBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                filterBtns.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');

                const filterValue = btn.getAttribute('data-filter');

                projectCards.forEach(card => {
                    if (filterValue === 'all' || card.getAttribute('data-category') === filterValue) {
                        card.classList.remove('hidden-card');
                    } else {
                        card.classList.add('hidden-card');
                    }
                });
            });
        });

        // Модальное окно
        const modal = document.getElementById('gallery-modal');
        const closeBtn = document.getElementById('modal-close');
        const openBtns = document.querySelectorAll('.open-modal-btn');
        
        // Modal elements
        const mTtitle = document.getElementById('modal-title');
        const mDesc = document.getElementById('modal-desc');
        const mTech = document.getElementById('modal-tech');
        const mRepo = document.getElementById('modal-repo-link');
        const mSite = document.getElementById('modal-site-link');

        // Carousel State
        let currentImages = [];
        let currentImageIndex = 0;
        const mainImg = document.getElementById('modal-main-image');
        const counter = document.getElementById('carousel-counter');
        const prevBtn = document.getElementById('carousel-prev');
        const nextBtn = document.getElementById('carousel-next');

        const updateCarousel = () => {
            if(currentImages.length > 0) {
                mainImg.src = currentImages[currentImageIndex];
                counter.textContent = `${currentImageIndex + 1} / ${currentImages.length}`;
            }
        };

        prevBtn.addEventListener('click', () => {
            if(currentImages.length > 1) {
                currentImageIndex = (currentImageIndex - 1 + currentImages.length) % currentImages.length;
                updateCarousel();
            }
        });
        nextBtn.addEventListener('click', () => {
            if(currentImages.length > 1) {
                currentImageIndex = (currentImageIndex + 1) % currentImages.length;
                updateCarousel();
            }
        });

        // Открытие модалки
        openBtns.forEach(btn => {
            btn.addEventListener('click', (e) => {
                const dataRaw = e.currentTarget.getAttribute('data-project');
                let p = {};
                try { p = JSON.parse(dataRaw); } catch(err) { return; }
                
                // Заполняем модалку
                mTtitle.textContent = p.title;
                mDesc.textContent = p.description;

                // Ссылки
                if(p.repo) { mRepo.href = p.repo; mRepo.classList.remove('hidden'); } else { mRepo.classList.add('hidden'); }
                if(p.site) { mSite.href = p.site; mSite.classList.remove('hidden'); } else { mSite.classList.add('hidden'); }

                // Карусель
                if(p.images && p.images.length > 0) {
                    currentImages = p.images;
                    currentImageIndex = 0;
                    updateCarousel();
                    if(p.images.length === 1) {
                        prevBtn.style.display = 'none';
                        nextBtn.style.display = 'none';
                        counter.style.display = 'none';
                    } else {
                        prevBtn.style.display = 'flex';
                        nextBtn.style.display = 'flex';
                        counter.style.display = 'block';
                    }
                }

                // Технологии
                mTech.innerHTML = '';
                if(p.technologies) {
                    p.technologies.forEach(t => {
                        const li = document.createElement('li');
                        li.className = 'tech-item flex items-center';
                        li.style.display = 'flex';
                        li.style.flexDirection = 'row';
                        li.style.alignItems = 'center';
                        li.style.gap = '6px';
                        li.style.whiteSpace = 'nowrap';
                        
                        if(t.iconPath || t.icon) {
                            const img = document.createElement('img');
                            img.src = t.iconPath || `${base}/icons/${t.icon}.svg`;
                            img.alt = t.name;
                            img.loading = 'lazy';
                            img.style.height = '16px';
                            img.style.maxHeight = '16px';
                            img.style.width = 'auto';
                            img.style.display = 'inline-block';
                            img.style.flexShrink = '0';
                            li.appendChild(img);
                        }
                        
                        const textSpan = document.createElement('span');
                        textSpan.textContent = t.name;
                        textSpan.style.lineHeight = '16px';
                        li.appendChild(textSpan);
                        
                        mTech.appendChild(li);
                    });
                }

                // Показываем
                modal.classList.add('active');
                document.body.style.overflow = 'hidden'; // prevent scroll
            });
        });

        // Закрытие модалки
        const closeModal = () => {
            modal.classList.remove('active');
            document.body.style.overflow = 'auto';
        };

        closeBtn.addEventListener('click', closeModal);
        modal.addEventListener('click', (e) => {
            if (e.target === modal) closeModal();
        });
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeModal();
        });
    });
</script>
