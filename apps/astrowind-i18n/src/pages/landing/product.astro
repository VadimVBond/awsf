---
import Layout from '~/layouts/LandingLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import { getLocaleFromUrl } from '~/i18n/translator';
import { lpByLocale } from '~/i18n/lp';

const locale = getLocaleFromUrl(Astro.url);
const lp = (lpByLocale[locale] || lpByLocale['en']).landings;

const metadata = {
  title: lp.product.metadata.title,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline={lp.product.hero.tagline}
    title={lp.product.hero.title}
    subtitle={lp.product.hero.subtitle}
    callToAction={{ text: lp.product.hero.cta, href: '#', icon: 'tabler:square-rounded-arrow-right' }}
    callToAction2={{ text: lp.product.hero.cta2, href: '#' }}
    image={{
      src: 'https://images.unsplash.com/photo-1473188588951-666fce8e7c68?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2174&q=80',
      alt: lp.product.hero.imageAlt,
    }}
  />

  <CallToAction
    title={lp.product.comingSoon.title}
    subtitle={lp.product.comingSoon.subtitle}
    callToAction={{
      text: lp.product.comingSoon.buttonText,
      href: 'https://github.com/onwidget/astrowind',
      icon: 'tabler:download',
    }}
  />
</Layout>
