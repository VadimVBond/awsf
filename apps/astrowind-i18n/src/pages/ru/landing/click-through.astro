---
import Layout from '~/layouts/LandingLayout.astro';

import Hero2 from '~/components/widgets/Hero2.astro';
import CallToAction from "~/components/widgets/CallToAction.astro"

import { getLocaleFromUrl } from '~/i18n/translator';
import { lpByLocale } from '~/i18n/lp';

const locale = getLocaleFromUrl(Astro.url);
const lp = (lpByLocale[locale] || lpByLocale['en']).landings;

const metadata = {
  title: lp.clickThrough.metadata.title,
};
---

<Layout metadata={metadata}>
  <!-- Hero2 Widget ******************* -->

  <Hero2
    tagline={lp.clickThrough.hero.tagline}
    title={lp.clickThrough.hero.title}
    subtitle={lp.clickThrough.hero.subtitle}
    callToAction={{ text: lp.clickThrough.hero.cta, href: '#', icon: 'tabler:square-rounded-arrow-right' }}
    callToAction2={{ text: lp.clickThrough.hero.cta2, href: '#' }}
    image={{
      src: 'https://images.unsplash.com/photo-1516321497487-e288fb19713f?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: lp.clickThrough.hero.imageAlt,
    }}
  />

  <CallToAction
    title={lp.clickThrough.comingSoon.title}
    subtitle={lp.clickThrough.comingSoon.subtitle}
    callToAction={{
      text: lp.clickThrough.comingSoon.buttonText,
      href: 'https://github.com/onwidget/astrowind',
      icon: 'tabler:download',
    }}
  />
</Layout>
