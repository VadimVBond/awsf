---
import Layout from '~/layouts/LandingLayout.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Gallery from '~/components/blocks/gallery/Gallery.astro';

import { getLocaleFromUrl } from '~/i18n/translator';
import { lpByLocale } from '~/i18n/lp';

const locale = getLocaleFromUrl(Astro.url);
const lp = (lpByLocale[locale] || lpByLocale['en']).landings;

const metadata = {
  title: 'Gallery - ' + lp.preLaunch.metadata.title,
};
---

<Layout metadata={metadata}>
  <!-- Hero2 Widget ******************* -->

  <Hero2
    tagline="Portfolio"
    title="Nuestros Proyectos"
    subtitle="Descubre nuestros proyectos recientes y casos de éxito."
    callToAction={{ text: "Go back", href: '/', icon: 'tabler:arrow-left' }}
    image={{
      src: 'https://images.unsplash.com/photo-1558803116-c1b4ac867b31?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2069&q=80',
      alt: lp.preLaunch.hero.imageAlt,
    }}
  />

  <!-- Блок Галереи -->
  <!-- В задании просили использовать include: {% include 'blocks/gallery/gallery.html' %} -->
  <!-- Но так как мы в Astro, мы используем компонент: -->
  <Gallery />

  <CallToAction
    title={lp.preLaunch.comingSoon.title}
    subtitle={lp.preLaunch.comingSoon.subtitle}
    callToAction={{
      text: lp.preLaunch.comingSoon.buttonText,
      href: 'https://github.com/onwidget/astrowind',
      icon: 'tabler:download',
    }}
  />
</Layout>
