---
// Import the necessary components
import MainLayout from '@/layouts/MainLayout.astro'
import ContactSection from '@components/sections/fr/ContactSection_fr.astro'
import { SITE } from '@data/constants'

const pageTitle: string = `Русский Nous Contacter | ${SITE.title}`
const metaDescription =
  'У вас есть вопросы или вы хотите обсудить проект? Свяжитесь с нами и создайте идеальное решение с нашими инструментами и услугами вместе.'
const ogTitle = 'Nous Contacter | ScrewFast'
---

<MainLayout
  title={pageTitle}
  lang="ru"
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': 'https://screwfast.uk/ru/contact',
    url: 'https://screwfast.uk/ru/contact',
    name: 'Русский Nous Contacter | ScrewFast',
    description:
      'У вас есть вопросы или вы хотите обсудить проект? Свяжитесь с нами и создайте идеальное решение с нашими инструментами и услугами вместе.',
    isPartOf: {
      '@type': 'WebSite',
      url: 'https://screwfast.uk/ru/',
      name: 'ScrewFast',
      description:
        'ScrewFast предлагает первоклассные строительные материалы и экспертные услуги для удовлетворения всех ваших потребностей в проекте.',
    },
    inLanguage: 'ru',
  }}
>
  <ContactSection />
</MainLayout>
